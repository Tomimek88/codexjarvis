{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/evidence_bundle.schema.json",
  "title": "EvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "timestamp_utc",
    "status",
    "domain",
    "input_hash",
    "params_hash",
    "code_hash",
    "env_hash",
    "seed",
    "artifacts",
    "logs",
    "metrics"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 8
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "FAILED",
        "PARTIAL"
      ]
    },
    "domain": {
      "type": "string",
      "enum": [
        "materials",
        "chemistry",
        "physics",
        "markets",
        "generic"
      ]
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "params_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "code_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "env_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "seed": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256",
          "kind"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "raw",
              "plot",
              "table",
              "model",
              "report"
            ]
          }
        }
      }
    },
    "logs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stdout",
        "stderr"
      ],
      "properties": {
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  }
}

